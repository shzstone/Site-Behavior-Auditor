msgid "次/分"
msgstr "req/min"

msgid "单 IP 每分钟请求超过此值自动封禁（0 为关闭）。"
msgstr "Block IP exceeding this request rate per minute (0 to disable)."

msgid "Gate 钥匙"
msgstr "Gate Key"

msgid "保护登录入口。访问 <code>wp-login.php?gate=钥匙</code> 开启入口，之后自动隐藏。"
msgstr "Protect login. Visit <code>wp-login.php?gate=KEY</code> to open."

msgid "追加拦截路径"
msgstr "Additional Block Paths"

msgid "逗号分隔。内置已含 .env/.git 等，此处用于扩充。"
msgstr "Comma-separated. .env/.git are built-in; use this to extend."

msgid "爬虫特征路径 (正则)"
msgstr "Crawler Path Patterns (Regex)"

msgid "正则表达式，匹配的 URL 将使用更严格的频率限制（默认阈值的 1/3）。"
msgstr "Regex pattern. Matched URLs use stricter limits (1/3 of threshold)."

msgid "Cookie 校验"
msgstr "Cookie Verification"

msgid "启用 Cookie 校验（无有效 Cookie 且非浏览器的请求将受到更严格限制）"
msgstr "Enable Cookie Check (Requests without cookies or valid UAs are restricted)."

msgid "拦截重定向 URL"
msgstr "Block Redirect URL"

msgid "拦截后将对方跳转至此页面（留空则显示默认 403 页面）。"
msgstr "Redirect blocked users to this URL (leave blank for 403 page)."

msgid "🔒 出站安全（SSRF 防御）"
msgstr "🔒 Outbound Security (SSRF Defense)"

msgid "DNS Rebinding 防御"
